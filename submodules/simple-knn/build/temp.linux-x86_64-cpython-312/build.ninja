ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /home/ubuntu/anaconda3/envs/3dgs/compiler_compat -fno-strict-overflow -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /home/ubuntu/anaconda3/envs/3dgs/include -fPIC -O2 -isystem /home/ubuntu/anaconda3/envs/3dgs/include -fPIC -I/home/ubuntu/anaconda3/envs/3dgs/lib/python3.12/site-packages/torch/include -I/home/ubuntu/anaconda3/envs/3dgs/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/home/ubuntu/anaconda3/envs/3dgs/include/python3.12 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_C -std=c++17
cuda_cflags = -I/home/ubuntu/anaconda3/envs/3dgs/lib/python3.12/site-packages/torch/include -I/home/ubuntu/anaconda3/envs/3dgs/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/home/ubuntu/anaconda3/envs/3dgs/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_C -gencode=arch=compute_86,code=sm_86 -gencode=arch=compute_89,code=sm_89 -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /data/ningzhh/code/FastGS/submodules/simple-knn/build/temp.linux-x86_64-cpython-312/ext.o: compile /data/ningzhh/code/FastGS/submodules/simple-knn/ext.cpp
build /data/ningzhh/code/FastGS/submodules/simple-knn/build/temp.linux-x86_64-cpython-312/simple_knn.o: cuda_compile /data/ningzhh/code/FastGS/submodules/simple-knn/simple_knn.cu
build /data/ningzhh/code/FastGS/submodules/simple-knn/build/temp.linux-x86_64-cpython-312/spatial.o: cuda_compile /data/ningzhh/code/FastGS/submodules/simple-knn/spatial.cu








